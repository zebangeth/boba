    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.5",
    "electron-vite": "^4.0.0",
    "typescript": "^5.9.3",
