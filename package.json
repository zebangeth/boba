{
  "name": "pawpal",
  "version": "0.1.3",
  "description": "A tiny desktop dog that helps you pause before you burn out.",
  "author": "zebangeth",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "test": "node scripts/test.mjs",
    "typecheck": "tsc --noEmit",
    "dist": "tsc --noEmit && electron-vite build && electron-builder --mac --win",
    "dist:mac": "tsc --noEmit && electron-vite build && electron-builder --mac",
    "dist:win": "tsc --noEmit && electron-vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.pawpal.app",
    "productName": "PawPal",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "dmg": {
      "title": "PawPal",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "pet_assets",
        "to": "pet_assets",
        "filter": ["**/*", "!.DS_Store"]
      }
    ]
  },
  "dependencies": {
    "electron-store": "^10.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.5",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
